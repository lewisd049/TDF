    vertical-align: middle;
    color: ${e=>e.textColor};
    background-color: ${e=>e.bgColor};
    font-size: 12px;
    font-weight: 500;
    padding: 8px;
    text-align: center;
    border-radius: 4px;
    width: 100%;
    svg{
      width: 13px;
      height: 13px;
      vertical-align: middle;
    }
    span{
      display: inline-block;
      vertical-align: middle;
      margin-left: 4px;
    }
  }
