    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    top: 16px;
    opacity: ${e=>e.isVisible?"1":"0"};
    transition: ${e=>e.isVisible?"opacity 0.3s 0.2s ease-in-out":"opacity 0.3s ease-in-out"};
    pointer-events: none;
